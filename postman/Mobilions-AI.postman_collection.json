        {
          "name": "Clear Chat History",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/api/chat/aria/history" }
        },
        {
          "name": "List All Conversations",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/conversations" }
        }
      ]
    },

