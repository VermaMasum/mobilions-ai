        {
          "name": "Chat with Agent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/chat/aria",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Help me write a LinkedIn post about AI productivity tools\"\n}"
            }
          }
        },
        {
          "name": "Get Chat History",
          "request": { "method": "GET", "url": "{{baseUrl}}/api/chat/aria/history" }
